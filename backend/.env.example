# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>/<db_name>?retryWrites=true&w=majority

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://visualise.co,https://www.visualise.co,https://abc-blue-chi.vercel.app

# ─── Nodemailer (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=you@example.com
SMTP_ALLOW_INVALID_CERT=false

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Seeded admin account (created on server boot if missing)
ADMIN_EMAIL=visualiseco@gmail.com
ADMIN_PASSWORD=ankur123456
ADMIN_JWT_SECRET=replace_with_long_random_secret

# Admin login rate limit
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_LOGIN_RATE_LIMIT_MAX=10

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
FORM_RATE_LIMIT_WINDOW_MS=3600000
FORM_RATE_LIMIT_MAX=10
